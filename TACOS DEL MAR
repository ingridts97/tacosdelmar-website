<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tacos del Mar | Catering de Mariscos en Querétaro</title>
    <meta name="description" content="Llevamos el auténtico sabor del mar a tu evento. Catering de tacos de pescado y camarón para bodas, cumpleaños y eventos corporativos en Querétaro.">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&display=swap" rel="stylesheet">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FoodEstablishment",
      "name": "Tacos del Mar Catering",
      "image": "https://picsum.photos/seed/tacosdelmar/1200/800",
      "description": "Catering móvil de tacos de mariscos para eventos privados en Querétaro, México.",
      "telephone": "+524420000000",
      "servesCuisine": "Mariscos, Mexican",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Santiago de Querétaro",
        "addressRegion": "QRO",
        "addressCountry": "MX"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "200"
      }
    }
    </script>

    <style>
        :root {
            --primary-red: #E8151B;
            --navy-blue: #1B3A8C;
            --sand-cream: #F5F3EE;
            --white: #FFFFFF;
            --text-body: #111111;
            --font-heading: 'Bebas Neue', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Reset */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-body);
            color: var(--text-body);
            background-color: var(--sand-cream);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Typography */
        h1, h2, h3, h4, h5, h6, .price, .btn, .nav-logo {
            font-family: var(--font-heading);
            font-weight: 400;
            line-height: 1.1;
            letter-spacing: 0.05em;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        ul {
            list-style: none;
        }

        img {
            max-width: 100%;
            height: auto;
            display: block;
        }

        /* Utilities */
        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1.5rem;
        }

        .text-center { text-align: center; }
        .text-white { color: var(--white); }
        .text-navy { color: var(--navy-blue); }
        .text-red { color: var(--primary-red); }
        .bg-navy { background-color: var(--navy-blue); }
        .bg-sand { background-color: var(--sand-cream); }
        .bg-white { background-color: var(--white); }
        .bg-red { background-color: var(--primary-red); }

        .section-padding { padding: 5rem 0; }
        
        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }
        .fade-up.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* Buttons */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.8rem 2rem;
            font-size: 1.25rem;
            border-radius: 50px;
            cursor: pointer;
            transition: var(--transition);
            border: 2px solid transparent;
        }

        .btn-red {
            background-color: var(--primary-red);
            color: var(--white);
        }
        .btn-red:hover {
            background-color: #c71217;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(232, 21, 27, 0.3);
        }

        .btn-outline-white {
            background-color: transparent;
            color: var(--white);
            border-color: var(--white);
        }
        .btn-outline-white:hover {
            background-color: var(--white);
            color: var(--navy-blue);
        }

        /* 1. Header & Nav */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            transition: var(--transition);
            padding: 1rem 0;
        }

        header.scrolled {
            background-color: var(--navy-blue);
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            padding: 0.5rem 0;
        }

        header.scrolled .nav-links a { color: var(--white); }
        header.scrolled .hamburger rect { fill: var(--white); }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-logo-wrap {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--primary-red);
            font-size: 2rem;
        }

        .nav-logo-wrap svg {
            width: 30px;
            height: 30px;
            fill: currentColor;
        }

        .nav-links {
            display: none;
            gap: 2rem;
            align-items: center;
            font-weight: 500;
            color: var(--white);
        }

        .nav-links a {
            position: relative;
        }
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 2px;
            background-color: var(--primary-red);
            transition: var(--transition);
        }
        .nav-links a:hover::after {
            width: 100%;
        }

        .hamburger {
            display: block;
            cursor: pointer;
            background: none;
            border: none;
        }

        .hamburger rect { fill: var(--white); transition: var(--transition); }

        /* Mobile Menu */
        .mobile-menu {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            background-color: var(--navy-blue);
            z-index: 999;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 2rem;
            transform: translateX(100%);
            transition: transform 0.4s ease-in-out;
        }

        .mobile-menu.open {
            transform: translateX(0);
        }

        .mobile-menu a {
            font-family: var(--font-heading);
            font-size: 2.5rem;
            color: var(--white);
        }

        .close-menu {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            background: none;
            border: none;
            color: var(--white);
            font-size: 2rem;
            cursor: pointer;
        }

        /* 2. Hero Section */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            padding-top: 5rem;
            overflow: hidden;
        }

        .hero-bg {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-color: var(--navy-blue);
            z-index: -2;
        }

        .hero-pattern {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            opacity: 0.05;
            background-image: url('data:image/svg+xml;utf8,<svg width="40" height="40" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg"><path d="M20 20.5V18H0v-2h20v-2h20v2H20v2.5z" fill="%23FFFFFF"/></svg>');
            z-index: -1;
        }

        .hero-content {
            display: grid;
            grid-template-columns: 1fr;
            gap: 3rem;
            align-items: center;
        }

        .hero-text h1 {
            font-size: clamp(3rem, 8vw, 5rem);
            margin-bottom: 1rem;
            line-height: 1;
        }

        .hero-text p.subhead {
            font-size: 1.125rem;
            color: rgba(255,255,255,0.7);
            margin-bottom: 2rem;
            max-width: 500px;
        }

        .hero-urgency {
            display: inline-block;
            background: rgba(232, 21, 27, 0.2);
            border: 1px solid var(--primary-red);
            color: var(--white);
            padding: 0.5rem 1rem;
            border-radius: 4px;
            font-size: 0.875rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
        }

        .hero-ctas {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .hero-trust {
            font-size: 0.875rem;
            color: rgba(255,255,255,0.6);
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .hero-illustration svg {
            width: 100%;
            max-width: 500px;
            height: auto;
            margin: 0 auto;
            display: block;
        }

        /* 3. Event Types */
        .section-header {
            text-align: center;
            margin-bottom: 3rem;
        }
        .section-header h2 {
            font-size: clamp(2.5rem, 5vw, 3.5rem);
        }

        .events-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .event-card {
            background-color: var(--white);
            border: 2px solid transparent;
            padding: 2rem;
            border-radius: 12px;
            text-align: center;
            transition: var(--transition);
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .event-card:hover {
            background-color: var(--navy-blue);
            transform: translateY(-5px);
            border-color: var(--navy-blue);
        }

        .event-icon {
            width: 60px;
            height: 60px;
            margin: 0 auto 1rem;
            fill: var(--navy-blue);
            transition: var(--transition);
        }

        .event-card h3 {
            font-size: 1.8rem;
            color: var(--navy-blue);
            margin-bottom: 0.5rem;
            transition: var(--transition);
        }

        .event-card p {
            font-size: 0.95rem;
            color: #555;
            transition: var(--transition);
        }

        .event-card:hover .event-icon { fill: var(--white); }
        .event-card:hover h3 { color: var(--white); }
        .event-card:hover p { color: rgba(255,255,255,0.8); }

        /* 4. How It Works */
        .steps-container {
            display: flex;
            flex-direction: column;
            gap: 2rem;
            position: relative;
        }

        .step-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 2rem;
            border-radius: 12px;
            text-align: center;
            position: relative;
            z-index: 2;
        }

        .step-number {
            font-family: var(--font-heading);
            font-size: 5rem;
            color: var(--primary-red);
            line-height: 1;
            margin-bottom: 1rem;
        }

        .step-card h3 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
        }

        .step-card p {
            color: rgba(255,255,255,0.7);
            font-size: 0.95rem;
        }

        /* 5. Menu Preview */
        .menu-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
            margin-bottom: 3rem;
        }

        .menu-card {
            background: var(--white);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            transition: var(--transition);
        }

        .menu-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.1);
        }

        .menu-img {
            height: 200px;
            width: 100%;
            object-fit: cover;
        }

        .menu-content {
            padding: 1.5rem;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .menu-content-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 0.5rem;
            gap: 1rem;
        }

        .menu-title {
            font-size: 1.8rem;
            color: var(--navy-blue);
        }

        .menu-price {
            font-size: 1.5rem;
            color: var(--primary-red);
            text-align: right;
            white-space: nowrap;
        }

        .menu-price small {
            display: block;
            font-family: var(--font-body);
            font-size: 0.75rem;
            color: #666;
            margin-top: -0.2rem;
        }

        .menu-desc {
            font-size: 0.9rem;
            color: #555;
            margin-bottom: 1rem;
        }

        /* 6. Social Proof */
        .testimonials-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .testimonial-card {
            background: var(--sand-cream);
            padding: 2rem;
            border-radius: 12px;
            position: relative;
        }

        .stars {
            display: flex;
            gap: 0.25rem;
            margin-bottom: 1rem;
        }
        .stars svg {
            width: 20px;
            height: 20px;
            fill: var(--primary-red);
        }

        .quote-text {
            font-size: 1rem;
            font-style: italic;
            margin-bottom: 1.5rem;
            color: var(--text-body);
        }

        .client-info {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .client-name {
            font-weight: 700;
            color: var(--navy-blue);
        }

        .event-badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.75rem;
            border: 1px solid var(--navy-blue);
            border-radius: 50px;
            color: var(--navy-blue);
            font-weight: 500;
        }

        /* 7. Booking CTA Band */
        .cta-band {
            position: relative;
            overflow: hidden;
            text-align: center;
        }
        
        .cta-band-watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 150%;
            height: 150%;
            opacity: 0.1;
            z-index: 1;
            pointer-events: none;
            background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"><path d="M10,50 Q30,20 50,50 T90,50 Q70,80 50,50 T10,50" fill="%23FFFFFF"/></svg>');
            background-repeat: no-repeat;
            background-position: center;
            background-size: cover;
        }

        .cta-band .container {
            position: relative;
            z-index: 2;
        }

        .cta-band h2 {
            font-size: clamp(2.5rem, 6vw, 4rem);
            margin-bottom: 0.5rem;
        }
        
        .cta-band p {
            font-size: 1.125rem;
            margin-bottom: 2rem;
            opacity: 0.9;
        }

        .cta-buttons {
            display: flex;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .btn-white {
            background-color: var(--white);
            color: var(--primary-red);
        }
        .btn-white:hover {
            background-color: #f0f0f0;
            transform: translateY(-2px);
        }

        /* 8. Contact Form */
        .contact-wrap {
            max-width: 700px;
            margin: 0 auto;
            background: var(--white);
            padding: 2.5rem;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.05);
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        label {
            display: block;
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: var(--navy-blue);
            font-size: 0.95rem;
        }

        input, select, textarea {
            width: 100%;
            padding: 0.8rem 1rem;
            border: 1px solid rgba(27, 58, 140, 0.2);
            border-radius: 8px;
            font-family: var(--font-body);
            font-size: 1rem;
            color: var(--text-body);
            background-color: var(--sand-cream);
            transition: var(--transition);
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--primary-red);
            box-shadow: 0 0 0 3px rgba(232, 21, 27, 0.1);
            background-color: var(--white);
        }

        .submit-btn {
            width: 100%;
            border: none;
            margin-top: 1rem;
        }

        .whatsapp-alt {
            text-align: center;
            margin-top: 1rem;
            font-size: 0.9rem;
        }
        .whatsapp-alt a {
            color: #25D366;
            font-weight: 700;
            text-decoration: underline;
        }

        /* 9. Footer */
        footer {
            border-top: 3px solid var(--primary-red);
            padding: 4rem 0 2rem;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
            margin-bottom: 3rem;
            text-align: center;
        }

        .footer-logo .nav-logo {
            font-size: 2.5rem;
            color: var(--primary-red);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }
        .footer-logo svg {
            width: 35px; height: 35px; fill: var(--white);
        }
        
        .footer-tagline {
            color: rgba(255,255,255,0.7);
            font-size: 0.9rem;
        }

        .footer-links ul {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        .footer-links a {
            color: var(--white);
            transition: var(--transition);
        }
        .footer-links a:hover {
            color: var(--primary-red);
        }

        .social-icons {
            display: flex;
            gap: 1rem;
            justify-content: center;
        }
        .social-icons a {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px; height: 40px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            transition: var(--transition);
        }
        .social-icons svg {
            width: 20px; height: 20px; fill: var(--white);
        }
        .social-icons a:hover {
            background: var(--primary-red);
            transform: translateY(-3px);
        }

        .footer-bottom {
            text-align: center;
            padding-top: 2rem;
            border-top: 1px solid rgba(255,255,255,0.1);
            font-size: 0.8rem;
            color: rgba(255,255,255,0.5);
        }

        /* Conversion Elements */
        .floating-whatsapp {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: #25D366;
            color: white;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            z-index: 99;
            transition: transform 0.3s ease;
        }
        .floating-whatsapp:hover {
            transform: scale(1.1);
        }
        .floating-whatsapp svg {
            width: 35px; height: 35px; fill: white;
        }
        .pulse-ring {
            position: absolute;
            width: 100%; height: 100%;
            border-radius: 50%;
            border: 2px solid #25D366;
            animation: pulse 2s infinite;
            z-index: -1;
        }
        @keyframes pulse {
            0% { transform: scale(1); opacity: 0.8; }
            100% { transform: scale(1.5); opacity: 0; }
        }
        .wa-tooltip {
            position: absolute;
            right: 75px;
            background: var(--white);
            color: var(--text-body);
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 700;
            white-space: nowrap;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
        }
        .wa-tooltip::after {
            content: '';
            position: absolute;
            right: -5px;
            top: 50%;
            transform: translateY(-50%);
            border-top: 6px solid transparent;
            border-bottom: 6px solid transparent;
            border-left: 6px solid var(--white);
        }
        .floating-whatsapp:hover .wa-tooltip {
            opacity: 1;
        }

        .mobile-sticky-bar {
            position: fixed;
            bottom: 0; left: 0; width: 100%;
            background: var(--navy-blue);
            padding: 1rem;
            box-shadow: 0 -4px 10px rgba(0,0,0,0.1);
            z-index: 98;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transform: translateY(100%);
            transition: transform 0.3s;
        }
        .mobile-sticky-bar.visible {
            transform: translateY(0);
        }
        .mobile-sticky-text {
            color: var(--white);
            font-size: 0.8rem;
            line-height: 1.2;
        }
        .mobile-sticky-text strong {
            display: block; font-size: 1rem;
        }
        .mobile-sticky-bar .btn {
            padding: 0.5rem 1.2rem; font-size: 1.1rem;
        }

        /* Media Queries */
        @media (min-width: 640px) {
            .events-grid { grid-template-columns: repeat(2, 1fr); }
            .menu-grid { grid-template-columns: repeat(2, 1fr); }
            .form-row { grid-template-columns: 1fr 1fr; }
            .hero-trust { flex-direction: row; gap: 1.5rem; }
        }

        @media (min-width: 1024px) {
            .nav-links { display: flex; }
            .hamburger { display: none; }
            .hero-content { grid-template-columns: 1fr 1fr; }
            .hero-text h1 { font-size: 5rem; }
            .events-grid { grid-template-columns: repeat(3, 1fr); }
            .steps-container { 
                flex-direction: row; 
            }
            .step-card { flex: 1; }
            .steps-container::after {
                content: '';
                position: absolute;
                top: 50px; left: 10%; width: 80%;
                border-top: 2px dashed var(--primary-red);
                z-index: 1;
            }
            .testimonials-grid { grid-template-columns: repeat(3, 1fr); }
            .footer-grid { grid-template-columns: 1fr 2fr 1fr; text-align: left; }
            .footer-logo .nav-logo, .social-icons { justify-content: flex-start; }
            .footer-links ul { flex-direction: row; justify-content: center; gap: 2rem; }
            .floating-whatsapp { bottom: 30px; right: 30px; width: 70px; height: 70px; }
            .mobile-sticky-bar { display: none !important; }
        }
    </style>
</head>
<body>

    <header id="header">
        <div class="container nav-container">
